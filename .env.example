# Scenema Audio — environment configuration
#
# Copy this file to `.env` (which is git-ignored) and fill in your values:
#   cp .env.example .env
#
# docker compose automatically loads `.env` from this directory.

# --- Required ---

# HuggingFace token with access to the gated google/gemma-3-12b-it model.
# Accept the license at https://huggingface.co/google/gemma-3-12b-it first,
# then create a read token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Base URL that OTHER machines (e.g. the agent host) reach this server at.
# Used to build the absolute audio_url returned by the podcast API.
# Set this to your Tailscale MagicDNS name or 100.x address — NOT localhost,
# or the agent won't be able to download the finished podcast.
PUBLIC_BASE_URL=http://gigatron:8000

# --- Optional podcast tuning (defaults shown; uncomment to override) ---

# MP3_BITRATE=128k          # encoded podcast bitrate
# TURN_GAP_S=0.4            # silence (seconds) inserted between speaker turns
# MAX_VOICE_CLIP_MB=25      # max size of an uploaded voice reference clip
# MAX_PODCAST_TURNS=500     # max turns allowed in one podcast submission
# PODCAST_TTL_DAYS=7        # job dirs older than this are swept on startup (0 = never)

# --- Optional server tuning ---

# GEMMA_QUANTIZE=nf4        # nf4 for <=24GB cards; empty for bf16 on 48GB+
# ENABLE_GRADIO=1           # serve the Gradio web UI at /ui
